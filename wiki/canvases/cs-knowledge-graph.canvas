{
	"nodes":[
		{"id":"title","type":"text","text":"# 🖥️ CS Knowledge Map\n### From Transistors to Agent Applications\n*Click any node to open its concept page*","x":0,"y":-520,"width":520,"height":100},
		{"id":"legend-done","type":"text","text":"🟢 Done  🟡 Active  ⚪ Todo","x":600,"y":-520,"width":280,"height":40},

		{"id":"label-physics","type":"text","text":"## ⚡ Physics Layer","x":-900,"y":-380,"width":200,"height":45,"color":"5"},
		{"id":"transistor","type":"text","text":"⚪ **Transistor**\nSemiconductor switch.\nNMOS/PMOS → CMOS.","x":-900,"y":-310,"width":220,"height":80},
		{"id":"logic-gate","type":"text","text":"⚪ **Logic Gate**\nAND/OR/NOT/NAND/NOR/XOR.\nBuilt from transistors.","x":-900,"y":-210,"width":220,"height":80},

		{"id":"label-hardware","type":"text","text":"## 🔧 Hardware Layer","x":-600,"y":-380,"width":200,"height":45,"color":"5"},
		{"id":"combinational","type":"text","text":"⚪ **Combinational Circuit**\nMux, decoder, ALU.\nOutput = f(input) only.","x":-600,"y":-310,"width":220,"height":80},
		{"id":"sequential","type":"text","text":"⚪ **Sequential Circuit**\nFlip-flop, register, counter.\nOutput = f(input, state).","x":-600,"y":-210,"width":220,"height":80},
		{"id":"cpu","type":"text","text":"⚪ **CPU Architecture**\nISA, pipeline, branch-pred,\ncache hierarchy.","x":-600,"y":-110,"width":220,"height":80},
		{"id":"memory-hierarchy","type":"text","text":"⚪ **Memory Hierarchy**\nRegister → L1/L2/L3 → RAM → SSD.\nLocality: temporal + spatial.","x":-350,"y":-210,"width":240,"height":80},

		{"id":"label-lowlevel","type":"text","text":"## 🧱 Low-Level Layer","x":-50,"y":-380,"width":200,"height":45,"color":"5"},
		{"id":"assembly","type":"text","text":"⚪ **Assembly**\nx86 / ARM / RISC-V.\nISA as human-readable machine code.","x":-50,"y":-310,"width":220,"height":80},
		{"id":"c-language","type":"text","text":"🟢 **C Language**\nPointers, memory layout,\nmanual allocation.\n→ Snake/Tetris projects","x":-50,"y":-210,"width":220,"height":90},
		{"id":"cpp-language","type":"text","text":"🟢 **C++**\nRAII, OOP, templates, STL.\n→ Snake (Scene polym.)\n→ Tetris (Block inherit.)","x":-50,"y":-100,"width":220,"height":100},
		{"id":"compilers","type":"text","text":"⚪ **Compilers**\nLexing → Parsing → IR →\nOptimization → Codegen.","x":200,"y":-310,"width":220,"height":80},

		{"id":"label-os","type":"text","text":"## 🪟 OS Layer","x":480,"y":-380,"width":200,"height":45,"color":"5"},
		{"id":"os-fundamentals","type":"text","text":"⚪ **Operating Systems**\nProcess/thread, virtual memory,\nfile system, syscalls.","x":480,"y":-310,"width":240,"height":80},
		{"id":"concurrency","type":"text","text":"⚪ **Concurrency**\nThread, mutex, semaphore,\natomic, lock-free, coroutine.","x":480,"y":-210,"width":240,"height":80},
		{"id":"networking","type":"text","text":"⚪ **Computer Networks**\nTCP/IP, HTTP, DNS, TLS.\nOSI 7-layer model.","x":480,"y":-110,"width":240,"height":80},

		{"id":"label-algo","type":"text","text":"## 📐 Algorithms Layer","x":790,"y":-380,"width":200,"height":45,"color":"5"},
		{"id":"data-structures","type":"text","text":"⚪ **Data Structures**\nArray, list, tree, hash,\ngraph, heap, trie.","x":790,"y":-310,"width":220,"height":80},
		{"id":"algorithms","type":"text","text":"⚪ **Algorithms**\nSort, search, DP, greedy,\ndivide-conquer, graph.","x":790,"y":-210,"width":220,"height":80},
		{"id":"complexity","type":"text","text":"⚪ **Complexity Theory**\nBig-O, P vs NP,\nundecidability, reduction.","x":790,"y":-110,"width":220,"height":80},

